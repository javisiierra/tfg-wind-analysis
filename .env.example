CDSAPI_URL=https://cds.climate.copernicus.eu/api
CDSAPI_KEY=<uid>:<api-key>

# OpenTopography API key used by WindNinja fetch_dem for SRTM DEM downloads.
# Create one at https://portal.opentopography.org/myopentopo.
CUSTOM_SRTM_API_KEY=<opentopography-api-key>
# Host folder that Docker will expose inside the backend container as /data.
HOST_CASES_ROOT=C:/Datos_TFG

# If WindNinja is installed inside the backend image, leave this as WindNinja_cli
# or set the absolute Linux path to the binary.
WINDNINJA_CLI=WindNinja_cli
